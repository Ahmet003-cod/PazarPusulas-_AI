# HausPort AI - Environment Variables
# Kopyalayıp .env olarak kaydedin ve değerleri doldurun

# OpenRouter API Key (LLM için)
# https://openrouter.ai/keys adresinden alabilirsiniz
OPENROUTER_API_KEY=

# Google Custom Search API
# https://console.cloud.google.com/ adresinden alabilirsiniz
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# Sunucu Ayarları
PORT=3000
